# Supabase Settings (Public & Service)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_public_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_private_key

# Cloudinary Settings (Direct Client-Side Unsigned Uploads)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_unsigned_preset_name

# PayPal API Settings
NEXT_PUBLIC_PAYPAL_ENABLED=false
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_API_URL=https://api-m.sandbox.paypal.com # or https://api-m.paypal.com for production
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id

# Admin Security Key
ADMIN_SECRET_KEY=your_admin_secret_key_here
